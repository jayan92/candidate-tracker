generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  applied
  screening
  interview
  offer
  hired
  rejected
}

enum CurrencyCode {
  USD
  EUR
  LKR
}

model Candidate {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  email       String    @unique
  phone       String?
  location    String?
  linkedinUrl String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  applications Application[]

  @@index([deletedAt])
}

model Application {
  id                String            @id @default(uuid()) @db.Uuid
  candidateId       String            @db.Uuid
  jobTitle          String
  company           String
  status            ApplicationStatus @default(applied)
  appliedAt         DateTime
  salaryExpectation Int?
  currencyCode      CurrencyCode      @default(USD)
  source            String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([status])
  @@index([appliedAt])
}
